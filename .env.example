# --- OT fill rates (OVERTIME REVIEW sheet — dashboard column next to call-out) ---
# https://docs.google.com/spreadsheets/d/1N_k9DsnIws2wWq_p1_mLe7ra6PInQ9rNZGknlfPCxls/edit
# OT_FILL_SPREADSHEET_ID=1N_k9DsnIws2wWq_p1_mLe7ra6PInQ9rNZGknlfPCxls
# OT_FILL_TAB=OVERTIME REVIEW
# Optional: sheet tab id from URL (gid=…) — avoids range errors if the visible tab title differs.
# OT_FILL_SHEET_GID=1000390321
# Raw open/filled are 30-min slot pairs → divide by 2 for hours (override with 1 if values are already hours).
# OT_FILL_SLOT_DIVISOR=2
# OT_FILL_CACHE_SECONDS=300
# Early-warning list (dashboard): dates ≥ today CT with fill % below this threshold (hours mode: requires open OT > 0).
# OT_FILL_WARNING_MAX_PCT=75
# OT_FILL_WARNING_MAX_ROWS=150
