# Paste full service account JSON in Netlify as GOOGLE_SERVICE_ACCOUNT_JSON (not this file).
# Local file: run `node scripts/bootstrap-local-env.js`
#
# Production API proxy (optional): **`npm run start:remote`** proxies `/api/*` here (ignored by **`npm start`**).
# Plain static servers can use **local-dashboard-dev.json** instead (browser reads it on localhost).
# DASHBOARD_API_ORIGIN=https://your-site.netlify.app
#
# Netlify production: prefer ONLY GOOGLE_SERVICE_ACCOUNT_JSON (+ optional ASSEMBLED_API_KEY).
# Importing this whole file can exceed Lambda's ~4KB env limit — see README and deploy-defaults.js.

# --- Net staffing: Assembled API (preferred) and/or Capacity Pull sheet ---
# Same ASSEMBLED_API_KEY as Capacity Pull Apps Script (Basic auth: key + ':').
ASSEMBLED_API_KEY=
ASSEMBLED_SITE_NAME=Consumer Sales
ASSEMBLED_CHANNEL=phone
ASSEMBLED_INTERVAL_SECONDS=1800
ASSEMBLED_PAGE_SIZE=20
ASSEMBLED_OP_START_MINUTE=420
ASSEMBLED_OP_END_MINUTE=1320
ASSEMBLED_API_BASE=https://api.assembledhq.com/v0
# net-staffing with ASSEMBLED_API_KEY needs outbound HTTPS/DNS from the runtime (Netlify Functions, or local smoke with network). Sandboxed CI without egress shows ENOTFOUND / “fetch failed”.
# Cache GET /sites and /queues in-process (seconds). Reduces duplicate calls and helps avoid Assembled 429s. 0 = disabled.
# ASSEMBLED_METADATA_CACHE_SECONDS=900
# Retries per Assembled request when HTTP 429 (respects Retry-After header when numeric).
# ASSEMBLED_RATE_LIMIT_MAX_ATTEMPTS=6

# assembled | auto — Assembled when ASSEMBLED_API_KEY is set; on DNS/network failure falls back to Capacity Pull sheet unless disabled below.
# sheet — Capacity Pull % only (skips Assembled; optional even with ASSEMBLED_API_KEY for debugging).
CAPACITY_PULL_SOURCE=auto
# 1 (default) = if Assembled fetch fails before HTTP (ENOTFOUND, timeout, etc.), use Capacity Pull sheet when CAPACITY_PULL_SPREADSHEET_ID is set.
# CAPACITY_PULL_FALLBACK_ON_ASSEMBLED_TRANSPORT=0
# NET_STAFFING_DISABLE_ASSEMBLED=1

# If Assembled net staffing API returns empty but you see staffing/net in Assembled for those queues, try omitting the site filter (queue+channel only):
# ASSEMBLED_SKIP_SITE_FILTER=1

# Second API pass WITHOUT site_id mixes every site for that queue — breaks parity with a site-filtered Staffing timeline.
# Only enable if Consumer Sales–scoped pulls return empty rows:
# ASSEMBLED_ALLOW_NO_SITE_RETRY=1

# Per-interval net (ASSEMBLED_NET_COMPUTE):
# api (recommended default) = staffing_net when numeric, else scheduled − forecasted — aligns with Surplus / typical timeline “Net” (timeline Net is often NOT Sched−Req from the two rows on screen).
# timeline = scheduled − forecasted only (ignores staffing_net) — debugging only.
# sched_minus_actual = scheduled − (required.actual ?? forecasted).
# Raw API dump: npm run assembled:inspect-forecast -- "High School_CC90_New"
# ASSEMBLED_NET_COMPUTE=timeline
#
# Optional Assembled dated API version header on every request (schedule filters sometimes depend on version):
# ASSEMBLED_API_VERSION=2019-06-20
# Duplicate schedule UUID as query param `schedule` if forecast ignores schedule_id alone:
# ASSEMBLED_FORECAST_DUP_SCHEDULE_PARAM=1

# Staffing timeline vs API: when schedule_id is omitted, Assembled uses **master schedule**, not necessarily
# “Default Schedule”. Pin UUID or use auto-resolve below.
# If auto-resolve fails in prod, run locally: npm run assembled:list-schedules
# ASSEMBLED_SCHEDULE_ID=
#
# Auto-resolve “Default Schedule” (cached with ASSEMBLED_METADATA_CACHE_SECONDS): tries several REST paths,
# then POST /graphql with common query shapes. Override name or disable:
# ASSEMBLED_SCHEDULE_MATCH_NAME=Default Schedule
# ASSEMBLED_SCHEDULE_AUTORESOLVE_OFF=1
# ASSEMBLED_SCHEDULE_MATCH_NAME=
# ASSEMBLED_SCHEDULE_GRAPHQL_OFF=1

# Optional: limit Assembled pulls to specific queues (comma-separated exact queue names from CAP_QUEUE_MAP).
# ASSEMBLED_NET_STAFFING_QUEUES=College and Grad TP_CC90_New

# Optional: avg (default) = mean of half-hour nets per clock hour (one agent change isn’t double-counted).
# sum = add both half-hours — ASSEMBLED_NET_STAFFING_HOUR_ROLLUP=sum

# Fallback sheet (Apps Script writes tab **Capacity Pull** — two-row header layout).
# Same workbook as Automated VTO bot:
# https://docs.google.com/spreadsheets/d/1gU2f7IQdlpWojwWnsQbpRP1Vge79I0tr4n1AjI1K3uw/edit
CAPACITY_PULL_SPREADSHEET_ID=1gU2f7IQdlpWojwWnsQbpRP1Vge79I0tr4n1AjI1K3uw
CAPACITY_PULL_TAB=Capacity Pull
CAPACITY_PULL_CACHE_SECONDS=180

