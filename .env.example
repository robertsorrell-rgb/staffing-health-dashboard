# ADHERENCE_INTRADAY_SNAPSHOT_SHEET_GID=
# ADHERENCE_INTRADAY_SNAPSHOT_RANGE='Intraday_Snapshot'!A1:Z600
ADHERENCE_DIGEST_URL=
ADHERENCE_CACHE_SECONDS=120

